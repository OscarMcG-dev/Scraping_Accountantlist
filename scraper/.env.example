# Required
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional — only needed for Attio dedup / People enrichment
ATTIO_API_KEY=
JINA_API_KEY=

# Directory scraper settings (only for main.py)
DIRECTORY_DELAY=1.0
DIRECTORY_MAX_CONCURRENT=5

# Crawl4AI settings
MAX_CONCURRENT_CRAWLS=5
PAGE_TIMEOUT=45000

# LLM settings
MAX_DECISION_MAKERS=3
LLM_TEMPERATURE=0.0

# Web search fallback — triggers when crawl finds no decision makers
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_MODEL=x-ai/grok-4.1-fast:online

# LLM link triage — use LLM to pick best sub-pages before crawling
LLM_LINK_TRIAGE=true

# Output directory
OUTPUT_DIR=data/output
